# Hugging Face Configuration
#
# This file stores your Hugging Face API token for accessing remote models.
# The token is used for authentication when calling Hugging Face Inference API.
#
# IMPORTANT: Keep this file secure and do not commit it to version control!
#
# To get your token:
# 1. Go to https://huggingface.co/settings/tokens
# 2. Create a new token or copy an existing one
# 3. Paste it below

HUGGINGFACE_TOKEN=<your_huggingface_token_here>

# Redirect HuggingFace model cache to F drive (C drive lacks space for large models)
HF_HUB_CACHE=F:\huggingface\hub

# OpenAI API key — required when using --llm-backend openai (or openai:<model>)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=<your_openai_api_key_here>